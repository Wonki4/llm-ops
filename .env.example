# ═══════════════════════════════════════════════════════════════
# LLM Ops Portal - Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ──── Database (shared by LiteLLM & custom backend) ────
POSTGRES_DB=litellm
POSTGRES_USER=llmproxy
POSTGRES_PASSWORD=dbpassword9090

# ──── LiteLLM Proxy ────
LITELLM_MASTER_KEY=sk-1234
STORE_MODEL_IN_DB=True
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ──── Custom Backend (APP_ prefix) ────
# Database
APP_DATABASE_URL=postgresql+asyncpg://llmproxy:dbpassword9090@db:5432/litellm
APP_DEBUG=false

# LiteLLM connection
APP_LITELLM_BASE_URL=http://litellm:4000
APP_LITELLM_ADMIN_API_KEY=sk-1234

# Keycloak SSO
APP_KEYCLOAK_BASE_URL=http://localhost:8082
APP_KEYCLOAK_INTERNAL_URL=http://keycloak:8080
APP_KEYCLOAK_REALM=litellm
APP_KEYCLOAK_CLIENT_ID=litellm-portal
APP_KEYCLOAK_CLIENT_SECRET=change-me-in-keycloak
APP_KEYCLOAK_REDIRECT_URI=http://localhost:3002/api/auth/callback
APP_KEYCLOAK_IDP_HINT=
APP_KEYCLOAK_SSL_VERIFY=

# JWT & Session
APP_JWT_AUDIENCE=litellm-portal
APP_SUPER_USER_ROLE=super_user
APP_ADMIN_GROUPS=[]
APP_SESSION_SECRET_KEY=change-me-in-production-must-be-32-bytes
APP_SESSION_COOKIE_NAME=litellm_session
APP_SESSION_COOKIE_SECURE=false
APP_SESSION_COOKIE_DOMAIN=
APP_SESSION_COOKIE_SAMESITE=lax
APP_SESSION_MAX_AGE=1209600

# Frontend URL (for CORS & redirects)
APP_FRONTEND_URL=http://localhost:3002
APP_CORS_ORIGINS=["http://localhost:3002"]

# Redis (catalog store)
APP_REDIS_URL=redis://redis:6379/0
APP_REDIS_PASSWORD=
APP_REDIS_CLUSTER=false
APP_REDIS_CATALOG_PREFIX=GENERATIVE:AI:
# Cluster multi-node example:
# APP_REDIS_URL=redis://node1:6379,redis://node2:6379,redis://node3:6379
# APP_REDIS_PASSWORD=mypassword
# APP_REDIS_CLUSTER=true

# Slack notifications (optional)
APP_SLACK_WEBHOOK_URL=

# ──── Keycloak Admin ────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ──── Frontend ────
NEXT_PUBLIC_API_URL=http://localhost:8002
