# ═══════════════════════════════════════════════════════════════
# LiteLLM Portal - Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ──── Database (shared by LiteLLM & custom backend) ────
POSTGRES_DB=litellm
POSTGRES_USER=llmproxy
POSTGRES_PASSWORD=dbpassword9090
DATABASE_URL=postgresql://llmproxy:dbpassword9090@db:5432/litellm

# ──── LiteLLM Proxy ────
LITELLM_MASTER_KEY=sk-1234
STORE_MODEL_IN_DB=True

# ──── Custom Backend ────
APP_DATABASE_URL=postgresql+asyncpg://llmproxy:dbpassword9090@db:5432/litellm
APP_LITELLM_BASE_URL=http://litellm:4000
APP_LITELLM_ADMIN_API_KEY=sk-1234
APP_CORS_ORIGINS=["http://localhost:3000"]
APP_DEBUG=false

# ──── Keycloak ────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
APP_KEYCLOAK_ISSUER=http://keycloak:8080/realms/litellm
APP_JWT_AUDIENCE=litellm-portal

# ──── Frontend (NextAuth) ────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=super-secret-nextauth-key-change-in-production
KEYCLOAK_CLIENT_ID=litellm-portal
KEYCLOAK_CLIENT_SECRET=change-me-in-keycloak
KEYCLOAK_ISSUER=http://localhost:8080/realms/litellm
NEXT_PUBLIC_API_URL=http://localhost:8000

# ──── Slack (optional) ────
APP_SLACK_WEBHOOK_URL=

# ──── LLM API Keys (for LiteLLM proxy) ────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
